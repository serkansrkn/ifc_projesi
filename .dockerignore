# Git & CI/CD
.git
.gitignore
.pytest_cache
__pycache__

# Python bytecode — TÜM alt dizinlerde (recursive)
# NOT: Dockerfile python:3.11 kullanır; yerel .pyc dosyaları (cpython-314)
# Docker build içinde zaten geçersizdir. Yeniden derlemeyi geciktirmemek
# için build context'e hiç alınmaması gerekir.
**/__pycache__/
**/*.pyc
**/*.pyo

# IDE
.vscode
.idea
*.swp
*.swo

# macOS
.DS_Store
**/.DS_Store

# Python packaging
*.egg-info
dist
build

# Docs / Reports (konteynerda gereksiz)
*.pdf
*.md
!README.md

# Çıktı dosyaları
output/
*.xlsx
*.json

# Test
tests/
